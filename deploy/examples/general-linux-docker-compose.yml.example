services:
  jerry-telemetry-agent:
    image: jerry-telemetry-agent:latest
    restart: "no"
    env_file:
      - general-linux-agent.env
    environment:
      AGENT_MODE: once
      TELEMETRY_OUTPUT_MODE: ${TELEMETRY_OUTPUT_MODE:-file}
      TELEMETRY_NODE_CONFIG_PATH: /config/general-linux-agent.node.json
      TELEMETRY_BATCH_OUTPUT_FILE: ${TELEMETRY_BATCH_OUTPUT_FILE:-/state/server.batch.safe.json}
      HEALTH_SERVER_ENABLED: ${HEALTH_SERVER_ENABLED:-false}
      HEALTH_HOST: 0.0.0.0
      HEALTH_PORT: ${HEALTH_PORT:-8081}
    volumes:
      - ./general-linux-agent.node.json:/config/general-linux-agent.node.json:ro
      - ./custom:/app/deploy/examples/custom:ro
      - ./state:/state
      - /var/run/docker.sock:/var/run/docker.sock:ro
    ports:
      - "127.0.0.1:${HEALTH_HOST_PORT:-18082}:8081"
