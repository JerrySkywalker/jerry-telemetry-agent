# General Linux server telemetry example. Placeholder-only.
AGENT_MODE=once
TELEMETRY_NODE_CONFIG_PATH=/config/general-linux-agent.node.json
TELEMETRY_NODE_ID=example-linux-01
TELEMETRY_HOSTNAME=example-linux-01
TELEMETRY_REGION=local
TELEMETRY_NODE_ROLE=general-linux-node
TELEMETRY_OUTPUT_MODE=file
TELEMETRY_BATCH_OUTPUT_FILE=/state/server.batch.safe.json
TELEMETRY_HUB_URL=http://127.0.0.1:3000/v1/events
TELEMETRY_NODE_SECRET=${TELEMETRY_NODE_SECRET_MANUALLY_SUPPLIED}
TELEMETRY_NODE_KEY_ID=${TELEMETRY_NODE_KEY_ID_OPTIONAL}
STATE_PATH=/state/agent-state.json
SPOOL_DIR=/state/spool

# HTTP upload is disabled by default. To test a local Hub, use scripts/server-agent-once.ps1
# with Output Push and manually supplied development credentials outside git.
