# Non-LAX pilot package example. Keep this file placeholder-only.
AGENT_MODE=once
TELEMETRY_NODE_CONFIG_PATH=/config/non-lax-agent-health.node.json
TELEMETRY_NODE_ID=example-node-01
TELEMETRY_HOSTNAME=example-node-01
TELEMETRY_REGION=example-region
TELEMETRY_NODE_ROLE=general-node
TELEMETRY_HUB_URL=https://telemetry.jerryskywalker.space/v1/events
TELEMETRY_NODE_SECRET=${TELEMETRY_NODE_SECRET_MANUALLY_SUPPLIED}
TELEMETRY_OUTPUT_MODE=file
TELEMETRY_AGENT_HEALTH_ENABLED=true
TELEMETRY_AGENT_HEALTH_OUTPUT_FILE=/state/agent-health-latest.safe.snapshot.json
STATE_PATH=/state/agent-state.json
SPOOL_DIR=/state/spool

# HTTP upload is intentionally disabled by default.
# To upload in a future approved goal, set TELEMETRY_OUTPUT_MODE=file,http and
# supply TELEMETRY_NODE_SECRET from a secret store outside git.
