# Names-only workstation Agent configuration template.
# Store the protected copy outside every immutable release slot.

AGENT_MODE=daemon
TELEMETRY_OUTPUT_MODE=file
TELEMETRY_NODE_CONFIG_PATH=<PROTECTED_NODE_CONFIG_PATH>
TELEMETRY_NODE_SECRET_FILE=<PROTECTED_SECRET_FILE_PATH>
TELEMETRY_NODE_KEY_ID=<OWNER_PROVIDED_KEY_ID_REFERENCE>
TELEMETRY_HUB_BATCH_URL=<OWNER_PROVIDED_HUB_BATCH_ENDPOINT>
TELEMETRY_HUB_REQUEST_TIMEOUT_MS=5000

TELEMETRY_SERVER_BATCH_LATEST_FILE=<STATE_ROOT>\server-batch.latest.safe.json
TELEMETRY_BATCH_OUTPUT_FILE=<STATE_ROOT>\server-batch.safe.json
STATE_PATH=<STATE_ROOT>\agent-state.json
SPOOL_DIR=<STATE_ROOT>\spool
SPOOL_MAX_FILES=100
SPOOL_MAX_BYTES=10485760
AGENT_INTERVAL_SECONDS=60

HEALTH_SERVER_ENABLED=true
HEALTH_HOST=127.0.0.1
HEALTH_PORT=<LOOPBACK_HEALTH_PORT>
