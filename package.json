{
  "name": "jerry-telemetry-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node-side telemetry agent for Jerry telemetry hub.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "ci:local": "npm run typecheck && npm test && npm run build",
    "release:gate:local": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/release-gate-local.ps1",
    "smoke:codex-backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-codex-backend-usage-local.ps1",
    "smoke:agent-health": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-agent-health-local.ps1",
    "smoke:non-lax-pilot": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-non-lax-pilot-local.ps1",
    "smoke:local-agent": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-local-agent.ps1",
    "agent:once": "tsx src/agent-once.ts",
    "server:once": "tsx src/server-agent-once.ts",
    "server:daemon": "tsx src/server-agent-daemon.ts",
    "doctor:agent-config": "tsx src/doctor-agent-config.ts",
    "deployment:plan": "tsx src/deployment-plan.ts",
    "canary:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-baseline-audit.ps1",
    "canary:baseline-gate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-baseline-gate-local.ps1",
    "canary:service-plan": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-service-baseline-plan-local.ps1",
    "canary:supervision-plan": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-agent-supervision-plan-local.ps1",
    "canary:live-audit-contract": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-live-audit-contract-local.ps1",
    "canary:rollback-plan": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-rollback-plan-local.ps1",
    "canary:live-audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-live-audit-readonly.ps1",
    "canary:soak": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-soak-readonly.ps1",
    "canary:report-summary": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canary-report-summarize-local.ps1",
    "smoke:local-hub-agent-e2e": "tsx src/local-hub-agent-e2e.ts",
    "smoke:local-hub-agent-e2e:once": "tsx src/local-hub-agent-e2e.ts --mode Once",
    "smoke:local-hub-agent-e2e:daemon": "tsx src/local-hub-agent-e2e.ts --mode Daemon",
    "smoke:workstation-release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/workstation/Test-AgentWorkstationRelease.ps1",
    "smoke:mg44-owner-resolver": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/workstation/Test-Mg44OwnerResolver.ps1",
    "smoke:workstation-colocated": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/workstation/Test-ColocatedGatewayAgentIntegration.ps1",
    "build:workstation-release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/workstation/New-AgentWorkstationRelease.ps1",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  }
}
